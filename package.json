{
  "name": "singpro-desktop",
  "version": "1.0.0",
  "description": "SingPro Desktop",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.singpro.desktop",
    "productName": "SingPro",
    "files": ["electron/**/*", "package.json"],
    "mac": { "target": ["dmg", "zip"] },
    "win": { "target": ["nsis", "portable"] },
    "linux": { "target": ["AppImage"] },
    "publish": {
      "provider": "github",
      "owner": "AntonioPiccirillo79",
      "repo": "singpro-desktop"
    }
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  }
}
